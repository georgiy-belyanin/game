[sub_resource type="GDScript" id="GDScript_t7iv1"]
script/source = "extends Node3D

var monster_scene = preload(\"res://monster.tscn\")
#var mp_rigidbody_scene = preload(\"res://objects/mp_rigidbody.tscn\")

func _ready() -> void:
	pass
	# Spawn a monster
	# rpc(\"spawn_monster\", multiplayer.get_unique_id(), Vector3(randf_range(-1, 1), 0, randf_range(-1, 1)))
	
	# Spawn 10 rigidbody objects
	#for i in range(10):
	#	var random_pos = Vector3(randf_range(-5, 5), randf_range(1, 3), randf_range(-5, 5))
	#	var object_name = \"rb_\" + str(multiplayer.get_unique_id()) + \"_\" + str(i)
	#	rpc(\"spawn_rigidbody\", multiplayer.get_unique_id(), random_pos, object_name)

@rpc(\"any_peer\", \"call_local\")
func spawn_monster(id, pos) -> void:
	print(str(multiplayer.get_unique_id()) + \"SPAWNING: \" + str(id))
	
	var monster = monster_scene.instantiate()
	monster.position = pos
	monster.name = str(id)
	monster.set_multiplayer_authority(id, true)
	
	add_child(monster, true)
"

