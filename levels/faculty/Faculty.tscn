[sub_resource type="GDScript" id="GDScript_ey5di"]
script/source = "extends Label3D

func _ready() -> void:
	Globals.game_start.connect(game_start)

func game_start() -> void:
	show()
	await get_tree().create_timer(10).timeout
	queue_free()
"

